FROM qwenllm/qwen3-asr:latest

# Устанавливаем зависимости клиента и библиотеку для скачивания
RUN pip install --no-cache-dir fastapi uvicorn websockets soundfile huggingface_hub

# Жестко задаем папку для кэша внутри контейнера
ENV HF_HOME=/models

# Скачиваем веса ASR-модели на этапе сборки образа (весит около 1.5 ГБ)
RUN python -c "from huggingface_hub import snapshot_download; snapshot_download('Qwen/Qwen3-ASR-1.7B')"

WORKDIR /workspace
COPY asr_server.py /workspace/asr_server.py

CMD ["uvicorn", "asr_server:app", "--host", "0.0.0.0", "--port", "8000"]
